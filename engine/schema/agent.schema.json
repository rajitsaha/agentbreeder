{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentBreeder Agent Configuration",
  "description": "Schema for agent.yaml \u2014 the agent definition file for AgentBreeder",
  "type": "object",
  "required": [
    "name",
    "version",
    "team",
    "owner",
    "framework",
    "model",
    "deploy"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "enum": [
        "v1"
      ],
      "default": "v1",
      "description": "Schema version"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 63,
      "description": "Agent name (slug-friendly)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Short description of the agent"
    },
    "team": {
      "type": "string",
      "description": "Team that owns this agent"
    },
    "owner": {
      "type": "string",
      "format": "email",
      "description": "Email of the responsible engineer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for discovery"
    },
    "framework": {
      "type": "string",
      "enum": [
        "langgraph",
        "crewai",
        "claude_sdk",
        "openai_agents",
        "google_adk",
        "custom"
      ],
      "description": "Agent framework"
    },
    "model": {
      "type": "object",
      "required": [
        "primary"
      ],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "description": "Primary model (registry ref or provider/model-id)"
        },
        "fallback": {
          "type": "string",
          "description": "Fallback model if primary is unavailable"
        },
        "gateway": {
          "type": "string",
          "description": "Model gateway (e.g., litellm)"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Model temperature"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum tokens per response"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "function"
            ]
          },
          "description": {
            "type": "string"
          },
          "schema": {
            "type": "object"
          }
        }
      },
      "description": "Tools and MCP servers"
    },
    "knowledge_bases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "properties": {
          "ref": {
            "type": "string"
          }
        }
      },
      "description": "Knowledge base references"
    },
    "prompts": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "description": "System prompt (ref or inline)"
        }
      },
      "description": "Prompt configuration"
    },
    "guardrails": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "endpoint": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        ]
      },
      "description": "Guardrail configuration"
    },
    "deploy": {
      "type": "object",
      "required": [
        "cloud"
      ],
      "additionalProperties": false,
      "properties": {
        "cloud": {
          "type": "string",
          "enum": [
            "aws",
            "azure",
            "gcp",
            "kubernetes",
            "local"
          ],
          "description": "Target cloud platform"
        },
        "runtime": {
          "type": "string",
          "description": "Deployment runtime (defaults per cloud)"
        },
        "region": {
          "type": "string",
          "description": "Cloud region"
        },
        "scaling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 0,
              "default": 1
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "default": 10
            },
            "target_cpu": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 70
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "default": "0.5"
            },
            "memory": {
              "type": "string",
              "default": "1Gi"
            }
          }
        },
        "env_vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Non-secret environment variables"
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Secret references"
        }
      }
    },
    "subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference to a subagent (e.g., agents/summarizer)"
          },
          "name": {
            "type": "string",
            "description": "Alias for this subagent (defaults to ref slug)"
          },
          "description": {
            "type": "string",
            "description": "What this subagent does (used for tool generation)"
          }
        }
      },
      "description": "Subagent references \u2014 auto-generates call_{name} tools"
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference to an MCP server (e.g., mcp/zendesk)"
          },
          "transport": {
            "type": "string",
            "enum": [
              "stdio",
              "sse",
              "streamable_http"
            ],
            "default": "stdio",
            "description": "Transport protocol"
          }
        }
      },
      "description": "MCP server references to attach as sidecars"
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "team",
            "private"
          ],
          "default": "team"
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_approval": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "crewai": {
      "type": "object",
      "description": "CrewAI-specific configuration. Only relevant when framework is crewai.",
      "properties": {
        "process": {
          "type": "string",
          "enum": [
            "sequential",
            "hierarchical",
            "parallel"
          ],
          "default": "sequential",
          "description": "Crew execution process type."
        },
        "manager_llm": {
          "type": "string",
          "description": "Model ref for the manager agent. Required when process=hierarchical."
        },
        "verbose": {
          "type": "boolean",
          "default": false
        },
        "memory": {
          "type": "boolean",
          "default": false
        },
        "memory_config": {
          "type": "object",
          "description": "Advanced memory provider config passed directly to Crew(memory_config=...).",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "google_adk": {
      "type": "object",
      "additionalProperties": false,
      "description": "Google ADK framework-specific configuration",
      "properties": {
        "session_backend": {
          "type": "string",
          "enum": [
            "memory",
            "database",
            "vertex_ai"
          ],
          "default": "memory",
          "description": "Session persistence backend"
        },
        "session_db_url": {
          "type": "string",
          "description": "SQLAlchemy database URL (required when session_backend=database)"
        },
        "memory_service": {
          "type": "string",
          "enum": [
            "memory",
            "vertex_ai_bank",
            "vertex_ai_rag"
          ],
          "default": "memory",
          "description": "Long-term memory service"
        },
        "artifact_service": {
          "type": "string",
          "enum": [
            "memory",
            "gcs"
          ],
          "default": "memory",
          "description": "Artifact storage backend"
        },
        "gcs_bucket": {
          "type": "string",
          "description": "GCS bucket name (required when artifact_service=gcs)"
        },
        "streaming": {
          "type": "string",
          "enum": [
            "none",
            "sse",
            "bidi"
          ],
          "default": "none",
          "description": "Streaming mode for RunConfig"
        }
      }
    },
    "claude_sdk": {
      "type": "object",
      "description": "Claude SDK advanced configuration (only applies when framework: claude_sdk)",
      "additionalProperties": false,
      "properties": {
        "thinking": {
          "type": "object",
          "description": "Adaptive thinking configuration (Opus 4.6 / Sonnet 4.6)",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable adaptive thinking"
            },
            "effort": {
              "type": "string",
              "enum": [
                "high",
                "medium",
                "low"
              ],
              "default": "high",
              "description": "Thinking effort level"
            }
          }
        },
        "prompt_caching": {
          "type": "boolean",
          "default": false,
          "description": "Auto-inject cache_control on long system prompts"
        },
        "routing": {
          "type": "object",
          "description": "Provider routing (Anthropic direct, Vertex AI, or AWS Bedrock)",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "anthropic",
                "vertex_ai",
                "bedrock"
              ],
              "default": "anthropic",
              "description": "Which provider endpoint to route to"
            },
            "project_id": {
              "type": "string",
              "description": "GCP project ID (required for vertex_ai)"
            },
            "region": {
              "type": "string",
              "description": "Cloud region (required for vertex_ai and bedrock)"
            }
          }
        }
      }
    }
  }
}
