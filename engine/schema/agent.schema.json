{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentBreeder Agent Configuration",
  "description": "Schema for agent.yaml \u2014 the agent definition file for AgentBreeder",
  "type": "object",
  "required": [
    "name",
    "version",
    "team",
    "owner",
    "model",
    "deploy"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "enum": [
        "v1"
      ],
      "default": "v1",
      "description": "Schema version"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 63,
      "description": "Agent name (slug-friendly)"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Short description of the agent"
    },
    "team": {
      "type": "string",
      "description": "Team that owns this agent"
    },
    "owner": {
      "type": "string",
      "format": "email",
      "description": "Email of the responsible engineer"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for discovery"
    },
    "type": {
      "type": "string",
      "enum": [
        "agent",
        "mcp-server"
      ],
      "default": "agent",
      "description": "Agent type"
    },
    "framework": {
      "type": "string",
      "enum": [
        "langgraph",
        "crewai",
        "claude_sdk",
        "openai_agents",
        "google_adk",
        "custom"
      ],
      "description": "Agent framework (Python agents)"
    },
    "runtime": {
      "type": "object",
      "required": [
        "language",
        "framework"
      ],
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string",
          "enum": [
            "python",
            "node",
            "go",
            "kotlin",
            "rust",
            "csharp"
          ],
          "description": "Runtime language. Tier 1 (full integrations): python, node. Tier 2 (SDK only): go (shipped), kotlin/rust/csharp (in-flight — Track I phase 1)."
        },
        "framework": {
          "type": "string",
          "description": "Runtime framework (open string \u2014 any value accepted)"
        },
        "version": {
          "type": "string",
          "description": "Language runtime version (e.g. '20' for Node 20)"
        },
        "entrypoint": {
          "type": "string",
          "description": "Custom entrypoint command"
        }
      },
      "description": "Polyglot runtime config (non-Python agents)"
    },
    "model": {
      "type": "object",
      "required": [
        "primary"
      ],
      "additionalProperties": false,
      "properties": {
        "primary": {
          "type": "string",
          "description": "Primary model (registry ref or provider/model-id)"
        },
        "fallback": {
          "type": "string",
          "description": "Fallback model if primary is unavailable"
        },
        "gateway": {
          "type": "string",
          "description": "Model gateway (e.g., litellm)"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2,
          "description": "Model temperature"
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum tokens per response"
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "function",
              "computer_use_20260401",
              "agent_toolset_20260401",
              "a2a"
            ],
            "description": "Tool type \u2014 use a2a to call another agent via Agent-to-Agent protocol, computer_use_20260401 for browser/computer use agents"
          },
          "description": {
            "type": "string"
          },
          "schema": {
            "type": "object"
          },
          "approval": {
            "type": "object",
            "description": "Human-in-the-loop approval config for this tool call",
            "additionalProperties": false,
            "properties": {
              "require": {
                "type": "boolean",
                "description": "If true, every call to this tool must be approved by a human before execution"
              },
              "timeout": {
                "type": "string",
                "description": "How long to wait for human approval before timing out (e.g. 30m, 1h)",
                "pattern": "^\\d+[smh]$"
              },
              "notify": {
                "type": "array",
                "description": "Notification channels \u2014 at least one Slack channel or email address",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "slack"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "slack": {
                          "type": "string",
                          "description": "Slack channel (e.g. #approvals)"
                        }
                      }
                    },
                    {
                      "type": "object",
                      "required": [
                        "email"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "email": {
                          "type": "string",
                          "format": "email"
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "description": "Tools and MCP servers"
    },
    "knowledge_bases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "properties": {
          "ref": {
            "type": "string"
          },
          "retrieval": {
            "type": "object",
            "additionalProperties": false,
            "description": "Retrieval configuration for this knowledge base",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "vector",
                  "graph",
                  "hybrid"
                ],
                "default": "vector",
                "description": "Retrieval strategy"
              },
              "hops": {
                "type": "integer",
                "minimum": 1,
                "maximum": 5,
                "default": 2,
                "description": "Graph traversal depth (graph/hybrid only)"
              },
              "top_k": {
                "type": "integer",
                "minimum": 1,
                "default": 10,
                "description": "Number of results to retrieve"
              },
              "rerank": {
                "type": "boolean",
                "default": true,
                "description": "Whether to rerank retrieved chunks"
              }
            }
          }
        }
      },
      "description": "Knowledge base references"
    },
    "prompts": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string",
          "description": "System prompt (ref or inline)"
        }
      },
      "description": "Prompt configuration"
    },
    "guardrails": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "description": "Built-in guardrail name (pii_detection, hallucination_check, content_filter, hitl_approve)"
          },
          {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "endpoint": {
                "type": "string",
                "format": "uri"
              },
              "action": {
                "type": "string",
                "enum": [
                  "block",
                  "warn",
                  "hitl_approve"
                ],
                "default": "block",
                "description": "Action on guardrail trigger \u2014 hitl_approve routes the call to the HITL approval queue"
              }
            }
          }
        ]
      },
      "description": "Guardrail configuration"
    },
    "deploy": {
      "type": "object",
      "required": [
        "cloud"
      ],
      "additionalProperties": false,
      "properties": {
        "cloud": {
          "type": "string",
          "enum": [
            "aws",
            "azure",
            "gcp",
            "kubernetes",
            "local",
            "claude-managed"
          ],
          "description": "Target cloud platform \u2014 claude-managed means Anthropic manages the runtime (no container built)"
        },
        "runtime": {
          "type": "string",
          "description": "Deployment runtime (defaults per cloud)"
        },
        "region": {
          "type": "string",
          "description": "Cloud region"
        },
        "scaling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "integer",
              "minimum": 0,
              "default": 1
            },
            "max": {
              "type": "integer",
              "minimum": 1,
              "default": 10
            },
            "target_cpu": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 70
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu": {
              "type": "string",
              "default": "0.5"
            },
            "memory": {
              "type": "string",
              "default": "1Gi"
            }
          }
        },
        "env_vars": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Non-secret environment variables"
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Secret references"
        },
        "identity": {
          "type": "object",
          "description": "Per-agent cloud IAM identity configuration \u2014 auto-creates an IAM Role (AWS) or Service Account (GCP) scoped to this agent",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean",
              "default": false,
              "description": "Auto-create a dedicated IAM role (AWS) or Service Account (GCP) for this agent"
            },
            "permissions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "AWS IAM permission strings in action:resource format (e.g. s3:GetObject:arn:aws:s3:::my-bucket/*)"
            },
            "roles": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "GCP IAM roles to grant the Service Account (e.g. roles/storage.objectViewer)"
            },
            "boundary": {
              "type": "string",
              "description": "AWS IAM permissions boundary ARN \u2014 limits the maximum effective permissions"
            }
          }
        },
        "sidecar": {
          "type": "object",
          "description": "Observability sidecar configuration \u2014 auto-injected OTel/cost/guardrail container",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true,
              "description": "Inject the AgentBreeder observability sidecar alongside the agent container"
            },
            "guardrails": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Guardrails to enforce in the sidecar (e.g. pii_detection, content_filter)"
            },
            "otel_endpoint": {
              "type": "string",
              "description": "Override the OpenTelemetry collector endpoint (defaults to OPENTELEMETRY_ENDPOINT env var)"
            },
            "cost_tracking": {
              "type": "boolean",
              "default": true,
              "description": "Enable token-level cost attribution in the sidecar"
            }
          }
        }
      }
    },
    "subagents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference to a subagent (e.g., agents/summarizer)"
          },
          "name": {
            "type": "string",
            "description": "Alias for this subagent (defaults to ref slug)"
          },
          "description": {
            "type": "string",
            "description": "What this subagent does (used for tool generation)"
          }
        }
      },
      "description": "Subagent references \u2014 auto-generates call_{name} tools"
    },
    "memory": {
      "type": "object",
      "description": "Memory store references \u2014 each entry must match a memory.yaml entry (redis buffer_window, postgresql entity, etc.)",
      "additionalProperties": false,
      "properties": {
        "stores": {
          "type": "array",
          "description": "List of memory store refs (e.g. session-buffer, entity-store)",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref"
        ],
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "description": "Registry reference to an MCP server (e.g., mcp/zendesk)"
          },
          "transport": {
            "type": "string",
            "enum": [
              "stdio",
              "sse",
              "streamable_http"
            ],
            "default": "stdio",
            "description": "Transport protocol"
          }
        }
      },
      "description": "MCP server references to attach as sidecars"
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "team",
            "private"
          ],
          "default": "team"
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "require_approval": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "gateways": {
      "type": "object",
      "description": "Per-gateway overrides for the catalog defaults (Track H / #164). Maps gateway name -> {url, api_key_env, fallback_policy, default_headers}. Long-term home is workspace.yaml (Track A / #146).",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "description": "Override the catalog base_url for this gateway."
          },
          "api_key_env": {
            "type": "string",
            "description": "Override the env var the gateway reads its api key from."
          },
          "fallback_policy": {
            "type": "string",
            "enum": ["fastest", "cheapest", "first"],
            "description": "Advisory routing hint when the gateway supports multiple upstreams. Not enforced yet."
          },
          "default_headers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "crewai": {
      "type": "object",
      "description": "CrewAI-specific configuration. Only relevant when framework is crewai.",
      "properties": {
        "process": {
          "type": "string",
          "enum": [
            "sequential",
            "hierarchical",
            "parallel"
          ],
          "default": "sequential",
          "description": "Crew execution process type."
        },
        "manager_llm": {
          "type": "string",
          "description": "Model ref for the manager agent. Required when process=hierarchical."
        },
        "verbose": {
          "type": "boolean",
          "default": false
        },
        "memory": {
          "type": "boolean",
          "default": false
        },
        "memory_config": {
          "type": "object",
          "description": "Advanced memory provider config passed directly to Crew(memory_config=...).",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "google_adk": {
      "type": "object",
      "additionalProperties": false,
      "description": "Google ADK framework-specific configuration",
      "properties": {
        "session_backend": {
          "type": "string",
          "enum": [
            "memory",
            "database",
            "vertex_ai"
          ],
          "default": "memory",
          "description": "Session persistence backend"
        },
        "session_db_url": {
          "type": "string",
          "description": "SQLAlchemy database URL (required when session_backend=database)"
        },
        "memory_service": {
          "type": "string",
          "enum": [
            "memory",
            "vertex_ai_bank",
            "vertex_ai_rag"
          ],
          "default": "memory",
          "description": "Long-term memory service"
        },
        "artifact_service": {
          "type": "string",
          "enum": [
            "memory",
            "gcs"
          ],
          "default": "memory",
          "description": "Artifact storage backend"
        },
        "gcs_bucket": {
          "type": "string",
          "description": "GCS bucket name (required when artifact_service=gcs)"
        },
        "streaming": {
          "type": "string",
          "enum": [
            "none",
            "sse",
            "bidi"
          ],
          "default": "none",
          "description": "Streaming mode for RunConfig"
        }
      }
    },
    "claude_managed": {
      "type": "object",
      "description": "Claude Managed Agents configuration \u2014 only read when deploy.cloud is claude-managed. No container is built; Anthropic manages the runtime.",
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "networking": {
              "type": "string",
              "enum": [
                "unrestricted",
                "restricted"
              ],
              "default": "unrestricted",
              "description": "Network access policy for the managed agent"
            }
          }
        },
        "tools": {
          "type": "array",
          "description": "Built-in tool types available to the managed agent",
          "items": {
            "type": "object",
            "required": [
              "type"
            ],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "description": "Tool type identifier (e.g. computer_use_20260401, agent_toolset_20260401)"
              }
            }
          }
        }
      }
    },
    "claude_sdk": {
      "type": "object",
      "description": "Claude SDK advanced configuration (only applies when framework: claude_sdk)",
      "additionalProperties": false,
      "properties": {
        "thinking": {
          "type": "object",
          "description": "Adaptive thinking configuration (Opus 4.6 / Sonnet 4.6)",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false,
              "description": "Enable adaptive thinking"
            },
            "effort": {
              "type": "string",
              "enum": [
                "high",
                "medium",
                "low"
              ],
              "default": "high",
              "description": "Thinking effort level"
            }
          }
        },
        "prompt_caching": {
          "type": "boolean",
          "default": false,
          "description": "Auto-inject cache_control on long system prompts"
        },
        "routing": {
          "type": "object",
          "description": "Provider routing (Anthropic direct, Vertex AI, or AWS Bedrock)",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "anthropic",
                "vertex_ai",
                "bedrock"
              ],
              "default": "anthropic",
              "description": "Which provider endpoint to route to"
            },
            "project_id": {
              "type": "string",
              "description": "GCP project ID (required for vertex_ai)"
            },
            "region": {
              "type": "string",
              "description": "Cloud region (required for vertex_ai and bedrock)"
            }
          }
        }
      }
    }
  },
  "oneOf": [
    {
      "required": [
        "framework"
      ],
      "properties": {
        "runtime": false
      }
    },
    {
      "required": [
        "runtime"
      ],
      "properties": {
        "framework": false
      }
    }
  ]
}
