# Required
DATABASE_URL=postgresql+asyncpg://agentbreeder:agentbreeder@localhost:5432/agentbreeder
REDIS_URL=redis://localhost:6379
SECRET_KEY=change-me-to-a-random-256-bit-key
AGENTBREEDER_ENV=development

# Optional — Cloud credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=

# Optional — Integrations
LITELLM_BASE_URL=http://localhost:4000
LANGSMITH_API_KEY=
OPENTELEMETRY_ENDPOINT=http://localhost:4317

# Optional — Auth
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GraphRAG (optional — only needed for graph/hybrid RAG indexes)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentbreeder
GRAPH_BACKEND=memory   # "memory" | "neo4j"
