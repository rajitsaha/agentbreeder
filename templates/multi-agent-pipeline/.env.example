# Multi-Agent Pipeline — Required Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Shared State Backend
REDIS_URL=redis://localhost:6379       # Required for production; not needed for local dev

# Optional: Pipeline Configuration
# QA_THRESHOLD=80                      # Min quality score to pass QA (0-100)
# MAX_REVISIONS=2                      # Max revision cycles before human escalation

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000

# Optional: Observability
# OPENTELEMETRY_ENDPOINT=http://localhost:4317
