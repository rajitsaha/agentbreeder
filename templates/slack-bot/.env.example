# Slack Bot Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# Slack Integration
SLACK_BOT_TOKEN=xoxb-xxxxx            # Bot User OAuth Token
SLACK_APP_TOKEN=xapp-xxxxx            # App-Level Token (for Socket Mode)
SLACK_SIGNING_SECRET=xxxxx            # Signing secret for verifying requests

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: Jira Integration
# JIRA_API_TOKEN=xxxxx                 # Jira API token
# JIRA_EMAIL=bot@company.com           # Jira account email
# JIRA_BASE_URL=https://company.atlassian.net

# Optional: Calendar Integration
# GOOGLE_CALENDAR_CREDENTIALS=path/to/creds.json
# OUTLOOK_CLIENT_ID=xxxxx

# Optional: Company Configuration
# COMPANY_NAME=Acme Corp

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
