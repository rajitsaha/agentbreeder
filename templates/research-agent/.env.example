# Research Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# Web Search API (choose one)
TAVILY_API_KEY=tvly-xxxxx              # Tavily search API (recommended)
# SERPER_API_KEY=xxxxx                 # Alternative: Serper search API
# BING_SEARCH_KEY=xxxxx               # Alternative: Bing Web Search API

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: Research Configuration
# MAX_SEARCH_QUERIES=15                # Max search queries per research task
# MAX_URLS_PER_QUERY=5                 # Max URLs to fetch per query
# REPORT_FORMAT=markdown               # Output format: markdown | json | html

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
