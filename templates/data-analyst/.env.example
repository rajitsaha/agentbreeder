# Data Analyst Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# Database Connection (read-only credentials recommended)
DATABASE_URL=postgresql://readonly_user:password@localhost:5432/analytics
# DATABASE_URL=mysql://readonly_user:password@localhost:3306/analytics
# DATABASE_URL=sqlite:///path/to/database.db

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: Query Safety
# DB_READ_ONLY=true                    # Enforce read-only mode (default: true)
# SQL_TIMEOUT_SECONDS=30               # Query timeout
# MAX_RESULT_ROWS=10000                # Max rows returned per query

# Optional: Chart Generation
# CHART_STYLE=seaborn                  # Matplotlib style: seaborn | ggplot | dark_background
# CHART_DPI=150                        # Output resolution

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
