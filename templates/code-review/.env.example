# Code Review Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# GitHub Integration
GITHUB_TOKEN=ghp_xxxxx                     # Personal access token or GitHub App token
                                            # Required scopes: repo, pull_requests
GITHUB_ORG=your-org                         # GitHub organization name
GITHUB_WEBHOOK_SECRET=whsec_xxxxx          # Optional: for webhook-triggered reviews

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx              # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx                     # Fallback model (GPT-4o)

# Optional: Review Configuration
# REVIEW_MAX_FILES=50                       # Skip review if PR has more files
# REVIEW_MAX_DIFF_LINES=2000               # Skip review if diff exceeds this

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
