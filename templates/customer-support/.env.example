# Customer Support Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# Zendesk Integration
ZENDESK_API_KEY=your-zendesk-api-key-here
ZENDESK_SUBDOMAIN=your-company              # e.g., "acme" for acme.zendesk.com
ZENDESK_EMAIL=support@company.com           # Agent email for Zendesk API

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx              # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx                     # Fallback model (GPT-4o)

# Optional: LiteLLM Gateway (if using centralized gateway)
# LITELLM_BASE_URL=http://localhost:4000

# Optional: Observability
# LANGSMITH_API_KEY=ls-xxxxx
# OPENTELEMETRY_ENDPOINT=http://localhost:4317
