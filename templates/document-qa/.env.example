# Document QA Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model + embeddings

# Optional: Vector Store Configuration
# QDRANT_URL=http://localhost:6333     # Qdrant vector database
# PINECONE_API_KEY=xxxxx              # Alternative: Pinecone
# WEAVIATE_URL=http://localhost:8080   # Alternative: Weaviate

# Optional: Embedding Configuration
# EMBEDDING_MODEL=text-embedding-3-small
# CHUNK_SIZE=512
# CHUNK_OVERLAP=50

# Optional: Search Configuration
# SEARCH_TOP_K=10                      # Number of passages to retrieve

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
