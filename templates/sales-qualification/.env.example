# Sales Qualification Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# CRM Integration (Salesforce, HubSpot, or Pipedrive)
CRM_API_KEY=your-crm-api-key
CRM_BASE_URL=https://api.hubspot.com  # Or your CRM's API base URL
# SALESFORCE_INSTANCE_URL=https://yourorg.salesforce.com
# SALESFORCE_ACCESS_TOKEN=xxxxx

# Company Enrichment
CLEARBIT_API_KEY=sk_xxxxx              # Clearbit for company enrichment
# APOLLO_API_KEY=xxxxx                 # Alternative: Apollo.io

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: Outreach Configuration
# QUALIFICATION_THRESHOLD=60           # Min score for automated outreach
# AUTO_OUTREACH_ENABLED=false          # Set true to auto-send outreach emails

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
