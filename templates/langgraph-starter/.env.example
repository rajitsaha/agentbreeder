# LangGraph Starter — Required Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000

# Optional: LangSmith Tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-xxxxx
# LANGCHAIN_PROJECT=langgraph-starter
