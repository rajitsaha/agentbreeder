# Email Triage Agent — Required Environment Variables
# Copy this file to .env and fill in your values

# Email Server (IMAP — for reading incoming emails)
IMAP_HOST=imap.gmail.com
IMAP_USER=triage@company.com
IMAP_PASSWORD=your-app-password        # Use app-specific password for Gmail

# Email Server (SMTP — for sending auto-replies)
SMTP_HOST=smtp.gmail.com
SMTP_USER=triage@company.com
SMTP_PASSWORD=your-app-password

# LLM Provider Keys
ANTHROPIC_API_KEY=sk-ant-xxxxx         # Primary model (Claude)
OPENAI_API_KEY=sk-xxxxx               # Fallback model (GPT-4o)

# Optional: Routing Configuration
# AUTO_REPLY_ENABLED=true              # Enable auto-draft replies
# AUTO_REPLY_MAX_PRIORITY=3            # Only auto-reply for priority <= this

# Optional: Slack Alerts (for priority 5 emails)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxxxx

# Optional: LiteLLM Gateway
# LITELLM_BASE_URL=http://localhost:4000
