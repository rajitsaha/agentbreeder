{
  "name": "@agentbreeder/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for AgentBreeder \u2014 Define Once. Deploy Anywhere.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "optionalPeerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "keywords": [
    "agent",
    "ai",
    "agentbreeder",
    "a2a",
    "mcp"
  ],
  "license": "Apache-2.0",
  "overrides": {
    "vite": "^6.4.2",
    "esbuild": "^0.25.0"
  }
}
