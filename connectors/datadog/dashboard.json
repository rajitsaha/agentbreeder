{
  "title": "AgentBreeder Fleet Metrics",
  "description": "AgentBreeder agent fleet observability — latency, cost, error rate, and invocation throughput.",
  "layout_type": "ordered",
  "is_read_only": false,
  "notify_list": [],
  "template_variables": [
    {
      "name": "env",
      "prefix": "env",
      "default": "production"
    },
    {
      "name": "agent",
      "prefix": "agent",
      "default": "*"
    }
  ],
  "widgets": [
    {
      "definition": {
        "type": "timeseries",
        "title": "Agent Invocations per Minute",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "sum:agentbreeder.agent.invocation{env:$env,agent:$agent}.as_rate()",
            "display_type": "bars",
            "style": {
              "palette": "dog_classic",
              "line_type": "solid",
              "line_width": "normal"
            }
          }
        ],
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "invocations/min",
          "min": "auto",
          "max": "auto"
        }
      },
      "layout": {"x": 0, "y": 0, "width": 6, "height": 3}
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Agent P50/P95/P99 Latency (ms)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "p50:agentbreeder.agent.latency{env:$env,agent:$agent}",
            "display_type": "line",
            "style": {"palette": "cool", "line_type": "solid", "line_width": "normal"},
            "metadata": [{"expression": "p50:agentbreeder.agent.latency{env:$env,agent:$agent}", "alias_name": "p50"}]
          },
          {
            "q": "p95:agentbreeder.agent.latency{env:$env,agent:$agent}",
            "display_type": "line",
            "style": {"palette": "warm", "line_type": "solid", "line_width": "normal"},
            "metadata": [{"expression": "p95:agentbreeder.agent.latency{env:$env,agent:$agent}", "alias_name": "p95"}]
          },
          {
            "q": "p99:agentbreeder.agent.latency{env:$env,agent:$agent}",
            "display_type": "line",
            "style": {"palette": "purple", "line_type": "solid", "line_width": "normal"},
            "metadata": [{"expression": "p99:agentbreeder.agent.latency{env:$env,agent:$agent}", "alias_name": "p99"}]
          }
        ],
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "ms"
        }
      },
      "layout": {"x": 6, "y": 0, "width": 6, "height": 3}
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Agent Error Rate (%)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "100 * sum:agentbreeder.agent.error{env:$env,agent:$agent}.as_rate() / sum:agentbreeder.agent.invocation{env:$env,agent:$agent}.as_rate()",
            "display_type": "line",
            "style": {"palette": "warm", "line_type": "solid", "line_width": "normal"}
          }
        ],
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "% error",
          "min": "0",
          "max": "100"
        },
        "markers": [
          {
            "value": "y = 5",
            "display_type": "error dashed",
            "label": "5% SLO threshold"
          }
        ]
      },
      "layout": {"x": 0, "y": 3, "width": 6, "height": 3}
    },
    {
      "definition": {
        "type": "timeseries",
        "title": "Token Cost per Agent (USD)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "sum:agentbreeder.agent.cost_usd{env:$env,agent:$agent} by {agent}",
            "display_type": "line",
            "style": {"palette": "green", "line_type": "solid", "line_width": "normal"}
          }
        ],
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "USD"
        }
      },
      "layout": {"x": 6, "y": 3, "width": 6, "height": 3}
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Total Invocations Today",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "sum:agentbreeder.agent.invocation{env:$env,agent:$agent}",
            "aggregator": "sum"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {"x": 0, "y": 6, "width": 3, "height": 2}
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Active Agents",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "count_nonzero(sum:agentbreeder.agent.invocation{env:$env} by {agent})",
            "aggregator": "last"
          }
        ],
        "autoscale": false,
        "precision": 0
      },
      "layout": {"x": 3, "y": 6, "width": 3, "height": 2}
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Avg Latency (ms)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "avg:agentbreeder.agent.latency{env:$env,agent:$agent}",
            "aggregator": "avg"
          }
        ],
        "autoscale": true,
        "precision": 0
      },
      "layout": {"x": 6, "y": 6, "width": 3, "height": 2}
    },
    {
      "definition": {
        "type": "query_value",
        "title": "Total Cost Today (USD)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "sum:agentbreeder.agent.cost_usd{env:$env,agent:$agent}",
            "aggregator": "sum"
          }
        ],
        "autoscale": true,
        "precision": 4
      },
      "layout": {"x": 9, "y": 6, "width": 3, "height": 2}
    },
    {
      "definition": {
        "type": "toplist",
        "title": "Top Agents by Invocation Volume",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "top(sum:agentbreeder.agent.invocation{env:$env} by {agent}, 10, 'sum', 'desc')",
            "style": {"palette": "dog_classic"}
          }
        ]
      },
      "layout": {"x": 0, "y": 8, "width": 6, "height": 4}
    },
    {
      "definition": {
        "type": "toplist",
        "title": "Top Agents by Cost",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "top(sum:agentbreeder.agent.cost_usd{env:$env} by {agent}, 10, 'sum', 'desc')",
            "style": {"palette": "warm"}
          }
        ]
      },
      "layout": {"x": 6, "y": 8, "width": 6, "height": 4}
    },
    {
      "definition": {
        "type": "heatmap",
        "title": "Latency Heatmap by Agent",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "q": "avg:agentbreeder.agent.latency{env:$env} by {agent}",
            "style": {"palette": "YlOrRd"}
          }
        ]
      },
      "layout": {"x": 0, "y": 12, "width": 12, "height": 4}
    }
  ]
}
