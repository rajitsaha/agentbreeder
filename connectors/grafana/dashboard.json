{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "AgentBreeder Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "AgentBreeder Loki data source",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AgentBreeder agent fleet observability — latency, cost, error rate, and invocation throughput.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Fleet Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 5000}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Active Agents",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(count by (agent) (agentbreeder_agent_invocation_total{env=\"$env\"}))",
          "legendFormat": "Active Agents"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 2000}
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Invocations / sec",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(agentbreeder_agent_invocation_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 5000}
            ]
          },
          "unit": "ms"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["mean"]}},
      "title": "Avg Latency",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "avg(agentbreeder_agent_latency_ms{env=\"$env\",agent=\"$agent\"})",
          "legendFormat": "Avg Latency"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(rate(agentbreeder_agent_error_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) / sum(rate(agentbreeder_agent_invocation_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval]))",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "id": 6,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["sum"]}},
      "title": "Total Cost Today",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(agentbreeder_agent_cost_usd_total{env=\"$env\",agent=\"$agent\"}[24h]))",
          "legendFormat": "USD"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 10,
      "title": "Latency & Throughput",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 11,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Agent Latency Percentiles (ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(agentbreeder_agent_latency_ms_bucket{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(agentbreeder_agent_latency_ms_bucket{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum(rate(agentbreeder_agent_latency_ms_bucket{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 12,
      "options": {"tooltip": {"mode": "multi"}},
      "title": "Invocations per Second by Agent",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(agentbreeder_agent_invocation_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (agent)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 20,
      "title": "Cost & Errors",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "currencyUSD", "custom": {"lineWidth": 2}}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 21,
      "title": "Token Cost per Agent (USD)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(agentbreeder_agent_cost_usd_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (agent)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "percent", "custom": {"lineWidth": 2}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "error_rate"},
            "properties": [
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 2}, {"color": "red", "value": 5}]}},
              {"id": "custom.thresholdsStyle", "value": {"mode": "area"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 22,
      "title": "Error Rate by Agent (%)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(rate(agentbreeder_agent_error_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (agent) / sum(rate(agentbreeder_agent_invocation_total{env=\"$env\",agent=\"$agent\"}[$__rate_interval])) by (agent)",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23},
      "id": 30,
      "title": "Agent Log Stream (Loki)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "id": 31,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "wrapLogMessage": false},
      "title": "Agent Metric Events",
      "type": "logs",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "expr": "{source=\"agentbreeder\",env=\"$env\",agent=\"$agent\"}",
          "legendFormat": ""
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["agentbreeder", "observability", "agents"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "production", "value": "production"},
        "hide": 0,
        "includeAll": false,
        "label": "Environment",
        "multi": false,
        "name": "env",
        "options": [
          {"selected": true, "text": "production", "value": "production"},
          {"selected": false, "text": "staging", "value": "staging"},
          {"selected": false, "text": "development", "value": "development"}
        ],
        "query": "production,staging,development",
        "type": "custom"
      },
      {
        "current": {"selected": true, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(agentbreeder_agent_invocation_total, agent)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent",
        "multi": false,
        "name": "agent",
        "query": {"query": "label_values(agentbreeder_agent_invocation_total, agent)", "refId": "agent"},
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentBreeder Fleet Metrics",
  "uid": "agentbreeder-fleet",
  "version": 1
}
